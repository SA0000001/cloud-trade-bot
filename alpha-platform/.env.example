# Alpha Platform — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to git.

# -------------------------------------------------------
# App
# -------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO

# -------------------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://alpha:alpha@localhost:5432/alpha_platform

# -------------------------------------------------------
# Redis
# -------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -------------------------------------------------------
# Telegram Bot
# -------------------------------------------------------
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# -------------------------------------------------------
# AI Reports (Anthropic Claude)
# -------------------------------------------------------
AI_REPORTS_ENABLED=false
AI_PROVIDER=anthropic
AI_API_KEY=sk-ant-your-key-here
AI_MODEL=claude-sonnet-4-5

# -------------------------------------------------------
# Paper Engine
# -------------------------------------------------------
PAPER_INITIAL_EQUITY=10000.0
PAPER_STATE_FILE=data/state/paper_engine_state.json

# -------------------------------------------------------
# Research
# -------------------------------------------------------
RESEARCH_DATA_DIR=data/historical
RESEARCH_RESULTS_DIR=data/results

# -------------------------------------------------------
# API
# -------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_SECRET_KEY=change-me-in-production-use-random-256-bit
